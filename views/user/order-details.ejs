<%- include("../../views/partials/user/header") %>

<div class="container my-5">

  <!-- Page Title -->
  <div class="text-center mb-4">
    <h2 class="fw-bold">Order Details</h2>
    <p class="text-muted">Thank you for your purchase!</p>
  </div>

  <!-- Order Info Card -->
  <div class="card shadow-sm mb-4">
    <div class="card-body d-flex justify-content-between flex-wrap">
      

      <div>
        <h6 class="text-muted mb-1">Payment Method</h6>
        <p class="fw-semibold mb-0"><%= order.paymentMethod %></p>
      </div>

      <div>
        <h6 class="text-muted mb-1">Order Status</h6>
        <span class="badge bg-success px-3 py-2"><%= order.status %></span>
      </div>

      <div>
        <h6 class="text-muted mb-1">Total Amount</h6>
        <p class="fw-bold text-success mb-0">INR <%= order.finalAmount %></p>
      </div>
    </div>
  </div>

  <!-- Products Card -->
  <div class="card shadow-sm mb-4">
    <div class="card-header bg-light">
      <h5 class="mb-0">Ordered Items</h5>
    </div>

    <div class="card-body p-0">
      <table class="table mb-0 align-middle">
        <thead class="table-light">
          <tr>
            <th>Product</th>
            <th class="text-center">Qty</th>
            <th class="text-end">Price</th>
            <th class="text-end">Total</th>
          </tr>
        </thead>
        <tbody>
          <% orderedItems.forEach(item => { %>
            <tr>
              <td><%= item.productName %></td>
              <td class="text-center"><%= item.quantity %></td>
              <td class="text-end">INR <%= item.price %></td>
              <td class="text-end fw-semibold">
                INR <%= item.quantity * item.price %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <!-- Price Summary -->
    <div class="card-footer bg-white">
      <div class="row justify-content-end">
        <div class="col-md-4">
          <ul class="list-group list-group-flush">
            <li class="list-group-item d-flex justify-content-between">
              <span>Discount</span>
              <span><%= order.discount %>%</span>
            </li>
            <li class="list-group-item d-flex justify-content-between fw-bold">
              <span>Total Amount</span>
              <span class="text-success">INR <%= order.finalAmount %></span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <!-- Shipping Address -->
  <div class="card shadow-sm mb-4">
    <div class="card-header bg-light">
      <h5 class="mb-0">Shipping Address</h5>
    </div>
    <div class="card-body">
      <% if (specificAddress) { %>
        <p class="mb-1 fw-semibold"><%= specificAddress.name %></p>
        <p class="mb-1">
          <%= specificAddress.houseName %>, <%= specificAddress.street %>
        </p>
        <p class="mb-1">
          <%= specificAddress.city %>, <%= specificAddress.state %> - <%= specificAddress.pincode %>
        </p>
        <p class="mb-0">
          Phone: <%= specificAddress.phone %>
          <% if (specificAddress.altPhone) { %>
            , Alt: <%= specificAddress.altPhone %>
          <% } %>
        </p>
      <% } else { %>
        <p class="text-muted">No shipping address found.</p>
      <% } %>
    </div>
  </div>

  <!-- Confirmation -->
  <div class="alert alert-success text-center shadow-sm">
    📧 A confirmation email has been sent with your order details.
  </div>

  <!-- Action Buttons -->
  <div class="d-flex justify-content-center gap-3 mt-4">
    <a href="/orders" class="btn btn-outline-primary">
      My Orders
    </a>
    <a href="/" class="btn btn-primary">
      Continue Shopping
    </a>
  </div>

</div>

<%- include("../../views/partials/user/footer") %>
