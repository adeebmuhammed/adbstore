<%- include("../../views/partials/user/header") %>

<div class="container mt-5 mb-5 profile-page">
  <div class="row">

    <!-- Sidebar -->
    <%- include("../../views/partials/user/profile-sidebar") %>

    <!-- Wallet Content -->
    <div class="col-md-9">

      <div class="card shadow-sm border-0 rounded">
        <div class="card-body">

          <h2 class="mb-4 fw-bold">Wallet</h2>

          <!-- Balance Section -->
          <div class="card border-0 shadow-sm mb-4 bg-light">
            <div class="card-body text-center">
              <h5 class="text-muted mb-2">Available Balance</h5>
              <h1 class="fw-bold text-success" id="balance">
                ₹ <%= wallet.balance.toFixed(2) %>
              </h1>
            </div>
          </div>

          <!-- Transaction History -->
          <div class="card border-0 shadow-sm">
            <div class="card-body">

              <h4 class="mb-3">Transaction History</h4>

              <div class="table-responsive">
                <table class="table table-hover align-middle">
                  <thead class="table-dark text-center">
                    <tr>
                      <th>Date</th>
                      <th>Transaction ID</th>
                      <th>Type</th>
                      <th>Amount</th>
                      <th>Description</th>
                    </tr>
                  </thead>

                  <tbody>
                    <% const txns = typeof transactions !== 'undefined' ? transactions : []; %>

                    <% if (txns.length > 0) { %>
                      <% txns.forEach(transaction => { %>
                        <tr class="text-center">

                          <td>
                            <%= new Date(transaction.date).toLocaleDateString() %>
                          </td>

                          <td class="fw-semibold">
                            <%= transaction.transaction_id %>
                          </td>

                          <td>
                            <span class="badge <%= transaction.type === 'credit' ? 'bg-success' : 'bg-danger' %>">
                              <%= transaction.type.charAt(0).toUpperCase() + transaction.type.slice(1) %>
                            </span>
                          </td>

                          <td class="fw-bold">
                            ₹ <%= transaction.amount.toFixed(2) %>
                          </td>

                          <td>
                            <%= transaction.description || 'N/A' %>
                          </td>

                        </tr>
                      <% }) %>

                    <% } else { %>

                      <tr>
                        <td colspan="5" class="text-center text-muted py-4">
                          No transactions found
                        </td>
                      </tr>

                    <% } %>
                  </tbody>
                </table>
              </div>

              <!-- Pagination -->
              <nav class="mt-4">
                <ul class="pagination justify-content-center">

                  <% if (currentPage > 1) { %>
                    <li class="page-item">
                      <a class="page-link" href="?page=<%= currentPage - 1 %>">
                        Previous
                      </a>
                    </li>
                  <% } %>

                  <% for (let i = 1; i <= totalPages; i++) { %>
                    <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                      <a class="page-link" href="?page=<%= i %>">
                        <%= i %>
                      </a>
                    </li>
                  <% } %>

                  <% if (currentPage < totalPages) { %>
                    <li class="page-item">
                      <a class="page-link" href="?page=<%= currentPage + 1 %>">
                        Next
                      </a>
                    </li>
                  <% } %>

                </ul>
              </nav>

            </div>
          </div>

        </div>
      </div>

    </div>
  </div>
</div>

<%- include("../../views/partials/user/footer") %>