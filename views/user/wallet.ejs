<%- include("../../views/partials/user/header") %>

<div class="container mt-5 profile-page">
  <div class="row">
    <!-- Sidebar -->
    <%- include("../../views/partials/user/profile-sidebar") %>

    <!-- Wallet Content Column -->
    <div class="col-md-9">
      <h2 class="mb-4">Wallet</h2>

      <!-- Balance Section -->
      <div class="card mb-4">
        <div class="card-body">
          <h4 class="card-title">Balance</h4>
          <p class="card-text display-4" id="balance">INR <%= wallet.balance.toFixed(2) %></p>
        </div>
      </div>

      <!-- Transaction History Table -->
      <div class="card">
        <div class="card-body">
          <h4 class="card-title">Transaction History</h4>
          <table class="table table-striped">
            <thead>
              <tr>
                <th>Date</th>
                <th>Transaction ID</th>
                <th>Type</th>
                <th>Amount</th>
                <th>Description</th>
              </tr>
            </thead>
            <tbody id="transaction-history">
<% const txns = typeof transactions !== 'undefined' ? transactions : []; %>

<% if (txns.length > 0) { %>
  <% txns.forEach(transaction => { %>
    <tr>
      <td><%= new Date(transaction.date).toLocaleDateString() %></td>
      <td><%= transaction.transaction_id %></td>
      <td><%= transaction.type.charAt(0).toUpperCase() + transaction.type.slice(1) %></td>
      <td>INR <%= transaction.amount.toFixed(2) %></td>
      <td><%= transaction.description || 'N/A' %></td>
    </tr>
  <% }) %>
<% } else { %>
  <tr>
    <td colspan="5" class="text-center">No transactions found</td>
  </tr>
<% } %>
</tbody>
          </table>

          <nav class="mt-3">
  <ul class="pagination justify-content-center">

    <% if (currentPage > 1) { %>
      <li class="page-item">
        <a class="page-link" href="?page=<%= currentPage - 1 %>">Previous</a>
      </li>
    <% } %>

    <% for (let i = 1; i <= totalPages; i++) { %>
      <li class="page-item <%= currentPage === i ? 'active' : '' %>">
        <a class="page-link" href="?page=<%= i %>"><%= i %></a>
      </li>
    <% } %>

    <% if (currentPage < totalPages) { %>
      <li class="page-item">
        <a class="page-link" href="?page=<%= currentPage + 1 %>">Next</a>
      </li>
    <% } %>

  </ul>
</nav>

        </div>
      </div>
    </div>
  </div>
</div>
</div>
</div>

<%- include("../../views/partials/user/footer") %>